@echo off
setlocal

set "PRG=%~0"
set "PRGDIR=%~dp0"
if "%PRGDIR%"=="" set "PRGDIR=."
set "APP_HOME=%PRGDIR%"

set "WRAPPER_DIR=%APP_HOME%gradle\wrapper"
set "WRAPPER_JAR=%WRAPPER_DIR%\gradle-wrapper.jar"
set "WRAPPER_PROPERTIES=%WRAPPER_DIR%\gradle-wrapper.properties"

if not exist "%WRAPPER_JAR%" (
  echo ERROR: Gradle wrapper jar not found: "%WRAPPER_JAR%"
  echo Run "gradle wrapper" to generate the required wrapper files.
  endlocal
  exit /b 1
)

if defined JAVA_HOME (
  set "JAVA_EXE=%JAVA_HOME%\bin\java.exe"
) else (
  set "JAVA_EXE=java"
)

if not defined JAVA_OPTS (
  set "JAVA_OPTS=-Xms128m -Xmx1g -Dfile.encoding=UTF-8"
)

"%JAVA_EXE%" %JAVA_OPTS% -classpath "%WRAPPER_JAR%" org.gradle.wrapper.GradleWrapperMain %*
set "RC=%ERRORLEVEL%"
endlocal & exit /b %RC%
